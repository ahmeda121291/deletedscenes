# Supabase — from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# server-only, used by export + upload pipeline; never expose to the client
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — server-only, powers Develop
ANTHROPIC_API_KEY=
# server-only; owner can swap models without a deploy.
# If the API rejects the model string, check current model IDs at
# https://docs.claude.com and update this value.
DEVELOP_MODEL=claude-sonnet-4-6

# TMDB — server-only, proxied through /api/tmdb/*
TMDB_API_KEY=

# Public site URL (used for RSS, sitemap, OG, copied links)
NEXT_PUBLIC_SITE_URL=https://deletedscenes.blog

# Darkroom entry theater — the codeword typed on the homepage to reveal the
# login modal. This is theater, NOT security: it ships in the client bundle
# by design. Real security is Supabase Auth + RLS + middleware.
NEXT_PUBLIC_DARKROOM_CODEWORD=rewind
